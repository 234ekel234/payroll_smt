<%= form_with(model: employee) do |f| %>

  <h6 class="mb-3">Basic Information</h6>

  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="col-md-6">
      <%= f.label :person_id, "Employee ID", class: "form-label" %>
      <%= f.text_field :person_id, class: "form-control", required: true %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.label :company, class: "form-label" %>
      <%= f.text_field :company, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :status_of_employment, class: "form-label" %>
      <%= f.select :status_of_employment,
            ["Regular", "Probationary", "Contractual"],
            { include_blank: "Select status" },
            class: "form-select" %>
    </div>
  </div>

  <h6 class="mt-4 mb-3">Pay Information</h6>

  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.label :basic_rate, "Basic Rate (per day)", class: "form-label" %>
      <%= f.number_field :basic_rate, step: 0.01, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :allowance_per_day, "Allowance (per day)", class: "form-control" %>
      <%= f.number_field :allowance_per_day, step: 0.01, class: "form-control" %>
    </div>
  </div>

  <div class="card bg-light border-0 mt-4 mb-3">
    <div class="card-body">
      <h6 class="mb-3 text-primary">Shift Assignment</h6>
      
      <div class="mb-3">
        <%= f.label :shift_id, "Assign to Group Shift Template", class: "form-label fw-bold" %>
        <%= f.collection_select :shift_id, Shift.order(:name), :id, :name, 
              { include_blank: "Individual / No Template" }, 
              { class: "form-select border-primary" } %>
        <div class="form-text">
          If a template is selected, the "Individual Times" below will be ignored during payroll.
        </div>
      </div>

      <hr class="my-4">

      <h6 class="mb-3 text-muted">Individual Times (Override)</h6>
      <div class="row mb-3">
        <div class="col-md-4">
          <%= f.label :shift_start, class: "form-label" %>
          <%= f.time_field :shift_start, class: "form-control" %>
        </div>

        <div class="col-md-4">
          <%= f.label :shift_end, class: "form-label" %>
          <%= f.time_field :shift_end, class: "form-control" %>
        </div>

        <div class="col-md-4">
          <%= f.label :schedule, "Schedule Name", class: "form-label" %>
          <%= f.text_field :schedule, class: "form-control", placeholder: "e.g. Day Shift" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <%= f.label :break_start, class: "form-label" %>
          <%= f.time_field :break_start, class: "form-control" %>
        </div>

        <div class="col-md-6">
          <%= f.label :break_end, class: "form-label" %>
          <%= f.time_field :break_end, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <h6 class="mt-4 mb-2">Work Days</h6>

  <div class="mb-3">
    <div class="row">
      <% Date::DAYNAMES.each do |day| %>
        <div class="col-md-3 col-sm-4 col-6">
          <div class="form-check">
            <%= check_box_tag "employee[work_days][]",
                  day,
                  employee.work_days.include?(day),
                  id: "employee_work_days_#{day}",
                  class: "form-check-input" %>

            <%= label_tag "employee_work_days_#{day}",
                  day,
                  class: "form-check-label" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="form-text mt-2">
      Select the days the employee is expected to work.
      Rest days will be calculated automatically.
    </div>
  </div>

  <div class="form-check mb-4">
    <%= f.check_box :landbank_atm, class: "form-check-input" %>
    <%= f.label :landbank_atm, "Has Landbank ATM", class: "form-check-label" %>
  </div>

  <div class="d-flex justify-content-end gap-2 mb-5">
    <%= link_to "Cancel", employees_path, class: "btn btn-secondary" %>
    <%= f.submit "Save Employee", class: "btn btn-primary px-4" %>
  </div>

<% end %>