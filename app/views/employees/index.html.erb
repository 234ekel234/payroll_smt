<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Employee Directory</h1>
    <%= link_to 'Add New Employee', new_employee_path, class: "btn btn-primary" %>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <%= form_with url: employees_path, method: :get, class: "row g-3" do |f| %>
        <div class="col-md-4">
          <%= f.text_field :query, placeholder: "Search by name or ID...", class: "form-control", value: params[:query] %>
        </div>
        <div class="col-md-3">
          <%= f.select :company, Employee.pluck(:company).uniq, { include_blank: "All Companies" }, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.submit "Filter", class: "btn btn-outline-secondary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Name / ID</th>
            <th>Company</th>
            <th>Basic Rate</th>
            <th>Schedule</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @employees.each do |employee| %>
            <tr>
              <td>
                <div class="fw-bold"><%= employee.name %></div>
                <small class="text-muted text-uppercase"><%= employee.person_id %></small>
              </td>
              <td><span class="badge bg-light text-dark border"><%= employee.company %></span></td>
              <td class="fw-bold"><%= number_to_currency(employee.basic_rate, unit: "₱") %></td>
              <td>
                <small class="d-block text-muted">
                  <%= employee.shift_start.strftime("%I:%M %p") %> - <%= employee.shift_end.strftime("%I:%M %p") %>
                </small>
              </td>
              <td>
                <span class="badge rounded-pill <%= employee.status_of_employment == 'Regular' ? 'bg-success' : 'bg-warning text-dark' %>">
                  <%= employee.status_of_employment %>
                </span>
              </td>
              <td class="text-end">
                <div class="btn-group">
                  <%= link_to "View", employee, class: "btn btn-sm btn-outline-primary" %>
                  <%= link_to "Edit", edit_employee_path(employee), class: "btn btn-sm btn-outline-secondary" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>