<%# app/views/employees/index.html.erb %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
      <h1 class="h3 mb-1 text-dark fw-bold">Employee Directory</h1>
      <p class="text-muted mb-0">Total Workforce: <span class="badge bg-secondary"><%= @employees.count %></span></p>
    </div>
    <%= link_to new_employee_path, class: "btn btn-primary shadow-sm rounded-pill" do %>
      <i class="bi bi-person-plus-fill me-1"></i> Add New Employee
    <% end %>
  </div>

  <%# --- Filter Section --- %>
  <div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body p-3">
      <%= form_with url: employees_path, method: :get, class: "row g-2 align-items-end", local: true do |f| %>
        <div class="col-md-5">
          <label class="small fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Search</label>
          <%= f.text_field :query, 
              placeholder: "Search by name or ID...", 
              class: "form-control form-control-sm border-0 shadow-sm", 
              value: params[:query] %>
        </div>
        
        <div class="col-md-4">
          <label class="small fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Company Filter</label>
          <%= f.select :company, 
              @companies, 
              { include_blank: "All Companies", selected: params[:company] }, 
              { class: "form-select form-select-sm border-0 shadow-sm" } %>
        </div>

        <div class="col-md-3 d-flex gap-2">
          <%= f.submit "Filter Results", class: "btn btn-sm btn-dark flex-grow-1 rounded-pill" %>
          <% if params[:query].present? || params[:company].present? %>
            <%= link_to "Reset List", employees_path, class: "btn btn-sm btn-outline-secondary rounded-pill" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- Bulk Update Form --- %>
  <%= form_with url: bulk_update_employees_path, method: :patch, local: true do |bulk_f| %>
    
    <div class="card shadow-sm border-0 mb-3 bg-white border-start border-primary border-4">
      <div class="card-body py-2 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <span class="small fw-bold text-primary text-uppercase">Bulk Actions:</span>
          
          <%= bulk_f.select :shift_id, 
              Shift.order(:name).pluck(:name, :id), 
              { include_blank: "Change Shift..." }, 
              { class: "form-select form-select-sm", style: "width: 180px;" } %>
          
          <%= bulk_f.select :company, 
              @companies, 
              { include_blank: "Move Company..." }, 
              { class: "form-select form-select-sm", style: "width: 180px;" } %>

          <%= bulk_f.submit "Apply Changes", 
              class: "btn btn-sm btn-primary rounded-pill px-3 shadow-sm", 
              data: { confirm: "Apply these changes to all selected employees?" } %>
        </div>
        <div class="text-muted small">
          Select employees below to begin
        </div>
      </div>
    </div>

    <%# --- Table Section --- %>
    <div class="card shadow-sm border-0 overflow-hidden">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light border-bottom">
            <tr>
              <th class="ps-4" style="width: 40px;">
                <input type="checkbox" class="form-check-input" id="selectAllEmployees">
              </th>
              <th class="text-muted fw-bold text-uppercase small">Employee</th>
              <th class="text-muted fw-bold text-uppercase small">Company</th>
              <th class="text-muted fw-bold text-uppercase small">Daily Comp. (Basic + Allw.)</th>
              <th class="text-muted fw-bold text-uppercase small text-center">Payment Method</th>
              <th class="text-muted fw-bold text-uppercase small">Schedule</th>
              <th class="text-muted fw-bold text-uppercase small">Status</th>
              <th class="text-end pe-4 text-muted fw-bold text-uppercase small">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @employees.any? %>
              <% @employees.each do |employee| %>
                <tr>
                  <td class="ps-4">
                    <%= check_box_tag "employee_ids[]", employee.id, false, class: "form-check-input employee-checkbox" %>
                  </td>
                  <td>
                    <div class="fw-bold text-dark"><%= employee.name %></div>
                    <div class="text-muted" style="font-size: 0.7rem;">ID: <span class="font-monospace text-uppercase"><%= employee.person_id %></span></div>
                  </td>
                  <td>
                    <span class="badge bg-white text-dark border fw-normal"><%= employee.company %></span>
                  </td>
                  
                  <%# --- UPDATED DAILY RATE COLUMN WITH LABELS --- %>
                  <td>
                    <% basic = employee.basic_rate || 0 %>
                    <% allowance = employee.allowance_per_day || 0 %>
                    <% total_rate = basic + allowance %>
                    
                    <div class="d-flex flex-column">
                      <div class="fw-bold text-success fs-6">
                        ₱<%= number_with_precision(total_rate, precision: 2, delimiter: ',') %>
                      </div>
                      
                      <div class="d-flex gap-1 align-items-center mt-1" style="font-size: 0.65rem;">
                        <span class="text-muted">Basic: ₱<%= number_with_precision(basic, precision: 0) %></span>
                        <% if allowance > 0 %>
                          <span class="text-muted">+</span>
                          <span class="text-primary fw-semibold">Allw: ₱<%= number_with_precision(allowance, precision: 0) %></span>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  
                  <td class="text-center">
                    <% if employee.landbank_atm %>
                      <span class="badge bg-info text-dark border border-info" style="font-size: 0.65rem; letter-spacing: 0.05rem;">
                        LANDBANK ATM
                      </span>
                    <% else %>
                      <span class="badge bg-light text-muted border" style="font-size: 0.65rem; letter-spacing: 0.05rem;">
                        CASH / MANUAL
                      </span>
                    <% end %>
                  </td>

                  <td>
                    <div class="mb-1">
                      <% if employee.shift %>
                        <span class="badge bg-primary-subtle text-primary border-0" style="font-size: 0.65rem;">
                          <%= employee.shift.name.upcase %>
                        </span>
                      <% else %>
                        <span class="badge bg-light text-muted border-0" style="font-size: 0.65rem;">INDIVIDUAL</span>
                      <% end %>
                    </div>
                    <div class="small fw-semibold text-secondary" style="font-size: 0.75rem;">
                      <%= employee.shift_start_time&.strftime("%I:%M %p") %> - <%= employee.shift_end_time&.strftime("%I:%M %p") %>
                    </div>
                  </td>
                  <td>
                    <span class="badge rounded-pill <%= employee.status_of_employment == 'Regular' ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning-emphasis' %>" style="font-size: 0.7rem;">
                      <%= employee.status_of_employment || 'Unknown' %>
                    </span>
                  </td>
                  <td class="text-end pe-4">
                    <div class="btn-group shadow-sm">
                      <%= link_to employee, class: "btn btn-sm btn-outline-primary" do %>View<% end %>
                      <%= link_to edit_employee_path(employee), class: "btn btn-sm btn-outline-secondary" do %>Edit<% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8" class="text-center py-5 text-muted">No employees found in directory.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const selectAll = document.getElementById('selectAllEmployees');
    const checkboxes = document.querySelectorAll('.employee-checkbox');

    if (selectAll) {
      selectAll.addEventListener('change', function() {
        checkboxes.forEach(cb => cb.checked = selectAll.checked);
      });
    }
  });
</script>