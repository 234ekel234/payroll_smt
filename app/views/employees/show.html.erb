<%# app/views/employees/show.html.erb %>
<div class="container mt-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Employees", employees_path %></li>
      <li class="breadcrumb-item active"><%= @employee.name %></li>
    </ol>
  </nav>

  <div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
      <h5 class="mb-0 fw-bold text-primary">Employee Profile</h5>
      <div class="d-flex gap-2">
        <%= link_to edit_employee_path(@employee), class: "btn btn-outline-primary btn-sm d-flex align-items-center" do %>
          <i class="bi bi-pencil me-1"></i> Edit
        <% end %>

        <%= button_to @employee, 
            method: :delete, 
            data: { confirm: "Are you sure? This will also affect associated payroll records." }, 
            class: "btn btn-outline-danger btn-sm" do %>
          <i class="bi bi-trash me-1"></i> Delete
        <% end %>
      </div>
    </div>

    <div class="card-body p-4">
      <div class="row">
        <%# Left Column: Identity %>
        <div class="col-md-6 border-end">
          <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">Employee ID</dt>
            <dd class="col-sm-8 fw-bold text-uppercase"><%= @employee.person_id %></dd>

            <dt class="col-sm-4 text-muted">Full Name</dt>
            <dd class="col-sm-8 h5 mb-3"><%= @employee.name %></dd>

            <dt class="col-sm-4 text-muted">Company</dt>
            <dd class="col-sm-8"><span class="badge bg-light text-dark border"><%= @employee.company %></span></dd>

            <dt class="col-sm-4 text-muted">Status</dt>
            <dd class="col-sm-8">
              <span class="badge rounded-pill <%= @employee.status_of_employment == 'Active' ? 'bg-success' : 'bg-warning text-dark' %>">
                <%= @employee.status_of_employment %>
              </span>
            </dd>

            <dt class="col-sm-4 text-muted pt-2">Payment Mode</dt>
            <dd class="col-sm-8 pt-2">
              <% if @employee.landbank_atm %>
                <span class="text-info"><i class="bi bi-credit-card-2-front me-1"></i> Landbank ATM</span>
              <% else %>
                <span class="text-secondary"><i class="bi bi-cash-stack me-1"></i> Cash</span>
              <% end %>
            </dd>
          </dl>
        </div>

        <%# Right Column: Compensation & Schedule %>
        <div class="col-md-6 ps-md-4">
          <dl class="row mb-0">
            <dt class="col-sm-5 text-muted">Basic Rate</dt>
            <dd class="col-sm-7 fw-bold text-success">
              <%= number_to_currency(@employee.basic_rate, unit: "₱") %>
            </dd>

            <dt class="col-sm-5 text-muted">Daily Allowance</dt>
            <dd class="col-sm-7">
              <%= number_to_currency(@employee.allowance_per_day, unit: "₱") %>
            </dd>

            <hr class="my-3 opacity-25">

            <dt class="col-sm-5 text-muted">Shift Time</dt>
            <dd class="col-sm-7">
              <i class="bi bi-clock me-1"></i>
              <%= @employee.shift_start&.strftime("%I:%M %p") %> – <%= @employee.shift_end&.strftime("%I:%M %p") %>
            </dd>

            <dt class="col-sm-5 text-muted">Break Time</dt>
            <dd class="col-sm-7">
              <%= @employee.break_start&.strftime("%I:%M %p") %> – <%= @employee.break_end&.strftime("%I:%M %p") %>
            </dd>

            <dt class="col-sm-5 text-muted mt-2">Work Days</dt>
            <dd class="col-sm-7 mt-2">
              <% @employee.work_days.each do |day| %>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><%= day %></span>
              <% end %>
            </dd>

            <dt class="col-sm-5 text-muted mt-1">Rest Days</dt>
            <dd class="col-sm-7 mt-1">
              <% @employee.rest_days.each do |day| %>
                <span class="badge bg-light text-muted border"><%= day %></span>
              <% end %>
            </dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="card-footer bg-light border-top-0 p-3 text-center">
      <%= link_to employees_path, class: "btn btn-link text-decoration-none text-muted" do %>
        <i class="bi bi-arrow-left me-1"></i> Back to Employee List
      <% end %>
    </div>
  </div>
</div>