<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1><i class="bi bi-gear-wide-connected"></i> Master Deductions List</h1>
      <p class="text-muted">Manage standard government rates and fixed company deductions.</p>
    </div>
    <%= link_to new_deduction_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle"></i> Create New Deduction
    <% end %>
  </div>

  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Deduction Name</th>
            <th>Category</th>
            <th>Calculation Type</th>
            <th class="text-end">Value/Rate</th>
            <th class="text-center">Status</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @deductions.each do |deduction| %>
            <tr>
              <td>
                <div class="fw-bold text-dark"><%= deduction.name %></div>
                <% if deduction.notes.present? %>
                  <small class="text-muted"><%= truncate(deduction.notes, length: 40) %></small>
                <% end %>
              </td>
              <td>
                <span class="badge rounded-pill bg-info text-dark">
                  <%= deduction.category&.titleize %>
                </span>
              </td>
              <td>
                <span class="text-uppercase small fw-bold text-muted">
                  <%= deduction.deduction_type&.humanize %>
                </span>
              </td>
              <td class="text-end fw-bold">
                <% if deduction.percentage? %>
                  <span class="text-primary"><%= deduction.amount %>%</span>
                <% else %>
                  <%= number_to_currency(deduction.amount, unit: "₱") %>
                <% end %>
              </td>
              <td class="text-center">
                <% if deduction.active %>
                  <span class="badge bg-success-subtle text-success border border-success-subtle">
                    <i class="bi bi-check-circle"></i> Active
                  </span>
                <% else %>
                  <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                    <i class="bi bi-x-circle"></i> Inactive
                  </span>
                <% end %>
              </td>
              <td class="text-center">
                <div class="btn-group">
                  <%= link_to deduction, class: "btn btn-sm btn-outline-secondary", title: "View" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= link_to edit_deduction_path(deduction), class: "btn btn-sm btn-outline-warning", title: "Edit" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to deduction, method: :delete, class: "btn btn-sm btn-outline-danger", 
                      data: { confirm: "Are you sure? This may affect future payroll generation." } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  
  <div class="mt-3">
    <small class="text-muted">
      <i class="bi bi-info-circle"></i> <strong>Tip:</strong> Deductions marked as "Government" use the 2026 Statutory Brackets for calculation.
    </small>
  </div>
</div>