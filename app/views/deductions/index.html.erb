<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h2"><i class="bi bi-gear-wide-connected text-primary"></i> Master Deductions List</h1>
      <p class="text-muted">Manage standard government rates and fixed company deductions.</p>
    </div>
    <%= link_to new_deduction_path, class: "btn btn-primary shadow-sm btn-lg" do %>
      <i class="bi bi-plus-circle"></i> Create New Deduction
    <% end %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3">Deduction Name</th>
            <th>Category</th>
            <th>Calc Type</th>
            <th class="text-end">Value/Rate</th>
            <th class="text-center">Status</th>
            <th class="text-end pe-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @deductions.each do |deduction| %>
            <tr class="<%= 'opacity-50 bg-light' unless deduction.active %>">
              <td class="ps-3">
                <div class="fw-bold text-dark"><%= deduction.name %></div>
                <% if deduction.notes.present? %>
                  <small class="text-muted d-block"><%= truncate(deduction.notes, length: 40) %></small>
                <% end %>
              </td>
              <td>
                <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle">
                  <%= deduction.category&.titleize %>
                </span>
              </td>
              <td>
                <span class="text-uppercase small fw-bold text-muted">
                  <%= deduction.amount_type&.humanize %>
                </span>
              </td>
              <td class="text-end fw-bold">
                <% if deduction.percentage? %>
                  <span class="text-primary"><%= deduction.amount %>%</span>
                <% else %>
                  <%= number_to_currency(deduction.amount, unit: "₱") %>
                <% end %>
              </td>
              <td class="text-center">
                <% if deduction.active %>
                  <span class="badge bg-success-subtle text-success border border-success px-3">
                    <i class="bi bi-check-circle"></i> Active
                  </span>
                <% else %>
                  <span class="badge bg-secondary-subtle text-secondary border border-secondary px-3">
                    <i class="bi bi-archive"></i> Archived
                  </span>
                <% end %>
              </td>
              <td class="text-end pe-3">
                <div class="d-flex justify-content-end gap-2">
                  <%= link_to edit_deduction_path(deduction), class: "btn btn-sm btn-outline-dark" do %>
                    <i class="bi bi-pencil"></i> Edit
                  <% end %>

                  <% if deduction.active %>
                    <%= button_to deduction_path(deduction), method: :delete, class: "btn btn-sm btn-outline-danger", 
                        form: { data: { confirm: "Archive this deduction? It will no longer apply to new payroll batches." } } do %>
                      <i class="bi bi-archive"></i> Archive
                    <% end %>
                  <% else %>
                    <%= button_to toggle_status_deduction_path(deduction), method: :patch, class: "btn btn-sm btn-outline-success" do %>
                      <i class="bi bi-arrow-counterclockwise"></i> Reactivate
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  
  <div class="mt-4 p-3 bg-light rounded border">
    <small class="text-muted">
      <i class="bi bi-info-circle-fill text-primary"></i> <strong>Pro Tip:</strong> 
      Archiving a deduction hides it from the Payroll Generator but preserves its history in your 
      past reports for auditing purposes.
    </small>
  </div>
</div>