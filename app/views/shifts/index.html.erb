<div class="mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
      <h1 class="h3 mb-1 fw-bold">Shift Templates</h1>
      <p class="text-muted mb-0">Work schedules that can be assigned to employees.</p>
    </div>
    <%= link_to new_shift_path, class: "btn btn-primary shadow-sm" do %>
      <i class="bi bi-plus-circle me-1"></i> Add Shift
    <% end %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3 text-muted small fw-bold text-uppercase">Name</th>
            <th class="text-muted small fw-bold text-uppercase">Hours</th>
            <th class="text-muted small fw-bold text-uppercase">Break</th>
            <th class="text-center text-muted small fw-bold text-uppercase">Employees</th>
            <th class="text-end pe-3 text-muted small fw-bold text-uppercase">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @shifts.any? %>
            <% @shifts.each do |shift| %>
              <tr>
                <td class="ps-3">
                  <div class="fw-bold text-dark"><%= shift.name %></div>
                </td>
                <td>
                  <span class="text-success fw-semibold"><%= shift.shift_start&.strftime("%I:%M %p") %></span>
                  <span class="text-muted mx-1">–</span>
                  <span class="text-danger fw-semibold"><%= shift.shift_end&.strftime("%I:%M %p") %></span>
                </td>
                <td class="text-muted small">
                  <% if shift.break_start && shift.break_end %>
                    <%= shift.break_start.strftime("%I:%M") %> – <%= shift.break_end.strftime("%I:%M %p") %>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                    <%= shift.employees.count %>
                  </span>
                </td>
                <td class="text-end pe-3">
                  <div class="btn-group btn-group-sm shadow-sm">
                    <%= link_to "Edit", edit_shift_path(shift), class: "btn btn-outline-secondary" %>
                    <%= button_to "Delete", shift_path(shift), method: :delete,
                          class: "btn btn-outline-danger",
                          form: { data: { turbo_confirm: "Delete this shift? Employees on this schedule will lose their assignment." } } %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="text-center py-5 text-muted">
                <i class="bi bi-clock h1 d-block"></i>No shifts defined yet.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
