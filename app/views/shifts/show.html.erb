<div class="mb-4 d-flex align-items-center justify-content-between">
  <h1>Shift Details: <span class="text-primary"><%= @shift.name %></span></h1>
  <div>
    <%= link_to "Edit Template", edit_shift_path(@shift), class: "btn btn-warning" %>
    <%= link_to "Back to Shifts", shifts_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="row">
  <div class="col-md-4">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="card-title mb-0">Schedule Overview</h5>
      </div>
      <div class="card-body">
        <ul class="list-group list-group-flush">
          <li class="list-group-item d-flex justify-content-between">
            <strong>Start Time:</strong>
            <span class="text-success fw-bold"><%= @shift.shift_start&.strftime("%I:%M %p") %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            <strong>End Time:</strong>
            <span class="text-danger fw-bold"><%= @shift.shift_end&.strftime("%I:%M %p") %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            <strong>Break Start:</strong>
            <span><%= @shift.break_start&.strftime("%I:%M %p") || "None" %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            <strong>Break End:</strong>
            <span><%= @shift.break_end&.strftime("%I:%M %p") || "None" %></span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Assigned Employees</h5>
        <span class="badge bg-light text-dark"><%= @shift.employees.count %> Total</span>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Company</th>
              <th>Status</th>
              <th class="text-end">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if @shift.employees.any? %>
              <% @shift.employees.each do |employee| %>
                <tr>
                  <td><%= employee.name %></td>
                  <td><%= employee.company %></td>
                  <td>
                    <% if employee.active %>
                      <span class="badge bg-success">Active</span>
                    <% else %>
                      <span class="badge bg-secondary">Inactive</span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <%= link_to "View Profile", employee_path(employee), class: "btn btn-sm btn-outline-primary" %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">
                  No employees are currently assigned to this shift template.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>