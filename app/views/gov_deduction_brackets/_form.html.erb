<%# app/views/gov_deduction_brackets/_form.html.erb %>

<%= form_with(model: gov_deduction_bracket, class: "row g-3") do |form| %>
  <% if gov_deduction_bracket.errors.any? %>
    <div class="alert alert-danger shadow-sm border-0">
      <h6 class="fw-bold"><%= pluralize(gov_deduction_bracket.errors.count, "error") %> prohibited this bracket from being saved:</h6>
      <ul class="mb-0 small">
        <% gov_deduction_bracket.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="col-md-12">
    <%= form.label :deduction_type, "Deduction Category", class: "form-label fw-bold small text-muted text-uppercase" %>
    <%# Using a select makes it impossible for users to enter the wrong ID %>
    <%= form.select :deduction_type, 
        [['SSS', 'sss'], ['PhilHealth', 'philhealth'], ['Pag-IBIG', 'pagibig']], 
        { prompt: "Select Type" }, 
        { class: "form-select border-0 shadow-sm" } %>
  </div>

  <div class="col-md-6">
    <%= form.label :range_min, "Salary Range From", class: "form-label fw-bold small text-muted text-uppercase" %>
    <div class="input-group shadow-sm">
      <span class="input-group-text border-0 bg-white">₱</span>
      <%= form.number_field :range_min, step: :any, class: "form-control border-0", placeholder: "0.00" %>
    </div>
  </div>

  <div class="col-md-6">
    <%= form.label :range_max, "Salary Range To", class: "form-label fw-bold small text-muted text-uppercase" %>
    <div class="input-group shadow-sm">
      <span class="input-group-text border-0 bg-white">₱</span>
      <%= form.number_field :range_max, step: :any, class: "form-control border-0", placeholder: "99999.99" %>
    </div>
  </div>

  <div class="col-md-12">
    <%= form.label :amount, "Fixed Amount (or Base for %)", class: "form-label fw-bold small text-muted text-uppercase" %>
    <div class="input-group shadow-sm">
      <span class="input-group-text border-0 bg-white">₱</span>
      <%= form.number_field :amount, step: :any, class: "form-control border-0", placeholder: "Enter fixed peso amount" %>
    </div>
    <div class="form-text text-muted" style="font-size: 0.75rem;">
      Note: For PhilHealth 2025/2026, logic will override this to 5% of basic salary.
    </div>
  </div>

  <div class="col-12 mt-4">
    <%= form.submit "Save Deduction Bracket", class: "btn btn-primary w-100 shadow-sm py-2 fw-bold" %>
  </div>
<% end %>