<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Government Brackets</h1>
    <%= link_to "New Bracket", new_gov_deduction_bracket_path, class: "btn btn-primary" %>
  </div>

  <%= form_with url: gov_deduction_brackets_path, method: :get, class: "row g-3 mb-4" do |f| %>
    <div class="col-auto">
      <%= f.select :query, 
                   GovDeductionBracket.deduction_types.keys.map { |k| [k.upcase, k] }, 
                   { include_blank: "All Agencies", selected: params[:query] }, 
                   { class: "form-select" } %>
    </div>
    <div class="col-auto">
      <%= f.submit "Filter", class: "btn btn-outline-secondary" %>
      <%= link_to "Reset", gov_deduction_brackets_path, class: "btn btn-link" %>
    </div>
  <% end %>

  <div class="card shadow-sm">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>Agency</th>
          <th>Range (Min - Max)</th>
          <th>Amount</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @gov_deduction_brackets.each do |bracket| %>
          <tr>
            <td><span class="badge bg-info text-dark"><%= bracket.deduction_type.upcase %></span></td>
            <td><%= number_to_currency(bracket.range_min, unit: "₱") %> - <%= number_to_currency(bracket.range_max, unit: "₱") %></td>
            <td class="fw-bold text-primary"><%= number_to_currency(bracket.amount, unit: "₱") %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_gov_deduction_bracket_path(bracket), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>