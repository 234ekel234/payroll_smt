<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <p style="color: green" class="mb-3"><%= notice %></p>

      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Pay Multipliers", pay_multipliers_path %></li>
          <li class="breadcrumb-item active"><%= @pay_multiplier.code %></li>
        </ol>
      </nav>

      <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
          <h5 class="mb-0">Payroll Rule Details</h5>
          <span class="badge bg-success fs-6">x<%= number_with_precision(@pay_multiplier.base_multiplier, precision: 2) %></span>
        </div>
        
        <div class="card-body p-4">
          <div class="row mb-4">
            <div class="col-sm-4 text-muted">Rule Name</div>
            <div class="col-sm-8 fw-bold fs-5"><%= @pay_multiplier.name %></div>
          </div>

          <div class="row mb-4">
            <div class="col-sm-4 text-muted">Identifier Code</div>
            <div class="col-sm-8">
              <code class="px-2 py-1 bg-light border rounded"><%= @pay_multiplier.code %></code>
            </div>
          </div>

          <hr>

          <h6 class="text-uppercase text-muted small fw-bold mb-3">Application Criteria</h6>
          
          <div class="row g-3">
            <div class="col-6 col-md-4">
              <div class="p-3 border rounded text-center <%= @pay_multiplier.holiday_type.to_s != 'none' ? 'bg-light border-warning' : '' %>">
                <small class="d-block text-muted">Holiday Type</small>
                <strong><%= @pay_multiplier.holiday_type&.capitalize || 'None' %></strong>
              </div>
            </div>

            <div class="col-6 col-md-4">
              <div class="p-3 border rounded text-center <%= @pay_multiplier.rest_day ? 'bg-light border-info' : '' %>">
                <small class="d-block text-muted">Rest Day</small>
                <strong><%= @pay_multiplier.rest_day ? 'YES' : 'NO' %></strong>
              </div>
            </div>

            <div class="col-6 col-md-4">
              <div class="p-3 border rounded text-center <%= @pay_multiplier.overtime ? 'bg-light border-primary' : '' %>">
                <small class="d-block text-muted">Overtime</small>
                <strong><%= @pay_multiplier.overtime ? 'YES' : 'NO' %></strong>
              </div>
            </div>
          </div>

          <div class="mt-4 p-3 bg-light rounded border-start border-success border-4">
            <p class="mb-0">
              <strong>Calculation Logic:</strong> 
              Hourly Rate × <%= number_with_precision(@pay_multiplier.base_multiplier, precision: 2) %> 
              = <strong><%= (@pay_multiplier.base_multiplier * 100).to_i %>%</strong> of basic pay.
            </p>
          </div>
        </div>

        <div class="card-footer bg-white py-3">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <%= link_to edit_pay_multiplier_path(@pay_multiplier), class: "btn btn-primary" do %>
                <i class="bi bi-pencil"></i> Edit Rule
              <% end %>
              <%= link_to "Back", pay_multipliers_path, class: "btn btn-outline-secondary ms-2" %>
            </div>
            
            <%= button_to @pay_multiplier, method: :delete, 
                form: { data: { confirm: "Are you sure you want to delete this payroll rule?" } },
                class: "btn btn-link text-danger text-decoration-none p-0" do %>
              Delete Rule
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>