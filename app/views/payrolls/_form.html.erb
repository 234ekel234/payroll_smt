<%= form_with(model: payroll, id: "payroll-form") do |f| %>
  <div class="row g-4">
    <div class="col-md-4">
      <%= f.label :employee_id, class: "form-label fw-bold" %>
      <%= f.collection_select :employee_id, Employee.all, :id, :name, { prompt: "Select Employee" }, { class: "form-select shadow-sm" } %>
    </div>
    <div class="col-md-4">
      <%= f.label :gross_pay, "Basic Gross for Period", class: "form-label fw-bold" %>
      <div class="input-group shadow-sm">
        <span class="input-group-text">₱</span>
        <%= f.number_field :gross_pay, step: :any, class: "form-control", placeholder: "0.00" %>
      </div>
    </div>
    <div class="col-md-4">
      <%= f.label :status, class: "form-label fw-bold" %>
      <%= f.select :status, [['Draft', 'draft'], ['Processed', 'processed']], {}, { class: "form-select" } %>
    </div>

    <hr class="my-5">

    <div class="row">
      <div class="col-md-5 border-end">
        <h5 class="text-primary mb-3"><i class="bi bi-bank"></i> Statutory Deductions</h5>
        <div class="p-3 bg-light rounded border">
          <%= f.collection_check_boxes :deduction_ids, Deduction.where(active: true), :id, :name do |b| %>
            <div class="form-check mb-2">
              <%# Pre-checks if the employee has this deduction assigned by default %>
              <%= b.check_box(class: "form-check-input", checked: payroll.employee&.deductions&.include?(b.object)) %>
              <%= b.label(class: "form-check-label fw-semibold") %>
              <div class="small text-muted"><%= b.object.category %></div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="text-danger mb-0"><i class="bi bi-pencil-square"></i> Manual Adjustments</h5>
          <button type="button" class="btn btn-sm btn-outline-danger" onclick="addManualRow()">
            <i class="bi bi-plus-lg"></i> Add Row
          </button>
        </div>

        <div id="manual-deductions-list">
          <%= f.fields_for :payroll_deductions do |pd| %>
            <% if pd.object.deduction_id.nil? %>
              <div class="input-group mb-2 manual-row-item">
                <%= pd.text_field :note, placeholder: "Description (e.g. Loan Payment)", class: "form-control" %>
                <span class="input-group-text">₱</span>
                <%= pd.number_field :amount, step: :any, placeholder: "0.00", class: "form-control" %>
                <button type="button" class="btn btn-outline-secondary" onclick="this.closest('.manual-row-item').remove()">
                  <i class="bi bi-x"></i>
                </button>
              </div>
            <% end %>
          <% end %>
        </div>
        <p class="small text-muted mt-2 fst-italic text-end">Note: Master deductions will be calculated automatically upon saving.</p>
      </div>
    </div>

    <div class="col-12 mt-5 py-3 border-top text-center">
      <%= f.submit "Save & Finalize Payroll", class: "btn btn-success btn-lg px-5 shadow" %>
    </div>
  </div>
<% end %>

<script>
  function addManualRow() {
    const list = document.getElementById('manual-deductions-list');
    const id = new Date().getTime(); // Unique ID for nested attributes
    const row = `
      <div class="input-group mb-2 manual-row-item animate__animated animate__fadeInDown">
        <input type="text" name="payroll[payroll_deductions_attributes][${id}][note]" 
               placeholder="Description" class="form-control" required>
        <span class="input-group-text">₱</span>
        <input type="number" name="payroll[payroll_deductions_attributes][${id}][amount]" 
               step="any" placeholder="0.00" class="form-control" required>
        <button type="button" class="btn btn-outline-secondary" onclick="this.closest('.manual-row-item').remove()">
          <i class="bi bi-x"></i>
        </button>
      </div>
    `;
    list.insertAdjacentHTML('beforeend', row);
  }
</script>