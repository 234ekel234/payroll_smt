<div class="container mt-5 mb-5">
  <%# --- HEADER NAVIGATION --- %>
  <div class="d-flex justify-content-between mb-4 d-print-none">
    <%= link_to payrolls_path, class: "btn btn-secondary shadow-sm" do %>
      <i class="bi bi-arrow-left"></i> Back to Payrolls
    <% end %>
    <%= link_to edit_payroll_path(@payroll), class: "btn btn-outline-primary shadow-sm" do %>
      <i class="bi bi-pencil"></i> Edit Record
    <% end %>
  </div>

  <div class="card shadow-sm border-0 mx-auto" style="max-width: 850px;">
    <div class="card-body p-5">
      <%# --- HEADER --- %>
      <div class="row mb-4">
        <div class="col-6">
          <h2 class="fw-bold mb-0 text-primary">PAYSLIP</h2>
          <p class="text-muted mb-0 small">Payroll ID: #<%= @payroll.id %></p>
          <p class="text-muted small">Period: <%= @payroll.start_date&.strftime("%b %d") %> - <%= @payroll.end_date&.strftime("%b %d, %Y") %></p>
        </div>
        <div class="col-6 text-end">
          <h5 class="fw-bold mb-0 text-uppercase"><%= @payroll.employee.name %></h5>
          <p class="text-muted small mb-1">Employee ID: <%= @payroll.employee.person_id %></p>
          <%
            status_class = case @payroll.status
                           when 'finalized' then 'bg-success'
                           when 'processed' then 'bg-primary'
                           else 'bg-warning text-dark'
                           end
          %>
          <span class="badge <%= status_class %>">
            <%= (@payroll.status || 'DRAFT').upcase %>
          </span>
        </div>
      </div>


      <div class="row bg-light rounded p-3 mb-4 g-2 border mx-0 align-items-center text-center">
        <div class="col-md-3 text-start">
          <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Gross Presence</small>
          <h5 class="mb-0 fw-bold"><%= @total_clocked_mins / 60 %>h <%= @total_clocked_mins % 60 %>m</h5>
        </div>
        <div class="col border-start">
          <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Regular</small>
          <h5 class="mb-0 fw-bold"><%= @slice_reg_mins / 60 %>h <%= @slice_reg_mins % 60 %>m</h5>
        </div>
        <div class="col border-start">
          <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Holiday/RD</small>
          <h5 class="mb-0 fw-bold"><%= (@slice_holiday_mins + @slice_rd_mins) / 60 %>h <%= (@slice_holiday_mins + @slice_rd_mins) % 60 %>m</h5>
        </div>
        <div class="col border-start">
          <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Overtime</small>
          <h5 class="mb-0 fw-bold"><%= @slice_ot_mins / 60 %>h <%= @slice_ot_mins % 60 %>m</h5>
        </div>
        <div class="col border-start">
          <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Night Diff</small>
          <h5 class="mb-0 fw-bold"><%= @slice_nd_mins / 60 %>h <%= @slice_nd_mins % 60 %>m</h5>
        </div>
      </div>

      <div class="row g-5">
        <%# --- EARNINGS COLUMN --- %>
        <div class="col-md-6 border-end">
          <h6 class="fw-bold border-bottom pb-2 text-uppercase small text-muted">Earnings Breakdown</h6>
          
          <div class="d-flex justify-content-between mb-2">
            <div>
              <span class="d-block">Basic Pay</span>
              <small class="text-muted">Rate: <%= number_to_currency(@payroll.daily_rate, unit: "₱") %></small>
            </div>
            <span class="fw-semibold"><%= number_to_currency(@payroll.basic_pay || 0, unit: "₱") %></span>
          </div>

          <% if @payroll.holiday_pay.to_f > 0 %>
            <div class="d-flex justify-content-between mb-2 text-danger">
              <span>Holiday Pay Premium</span>
              <span class="fw-bold">+ <%= number_to_currency(@payroll.holiday_pay, unit: "₱") %></span>
            </div>
          <% end %>

          <% if @payroll.rest_day_pay.to_f > 0 %>
            <div class="d-flex justify-content-between mb-2">
              <span>Rest Day Pay</span>
              <span class="fw-bold">+ <%= number_to_currency(@payroll.rest_day_pay, unit: "₱") %></span>
            </div>
          <% end %>

          <% if @payroll.overtime_pay.to_f > 0 %>
            <div class="d-flex justify-content-between mb-2 text-primary">
              <span>Overtime Pay</span>
              <span>+ <%= number_to_currency(@payroll.overtime_pay, unit: "₱") %></span>
            </div>
          <% end %>

          <% if @payroll.night_diff_pay.to_f > 0 %>
            <div class="d-flex justify-content-between mb-2 text-info">
              <span>Night Differential</span>
              <span>+ <%= number_to_currency(@payroll.night_diff_pay, unit: "₱") %></span>
            </div>
          <% end %>

          <% if @payroll.allowance.to_f > 0 %>
            <div class="d-flex justify-content-between mb-1 text-success">
              <span>Allowances</span>
              <span>+ <%= number_to_currency(@payroll.allowance, unit: "₱") %></span>
            </div>
          <% end %>

          <div class="d-flex justify-content-between fw-bold pt-2 border-top mt-3 bg-light p-2 rounded">
            <span>GROSS EARNINGS</span>
            <span><%= number_to_currency(@payroll.gross_pay || 0, unit: "₱") %></span>
          </div>
        </div>

        <%# --- DEDUCTIONS COLUMN --- %>
        <div class="col-md-6">
          <h6 class="fw-bold border-bottom pb-2 text-uppercase small text-muted">Deductions Breakdown</h6>
          
          <%# Quick Fix: Combine hardcoded schema columns into a list %>
          <% 
            fixed_deductions = [
              { name: "SSS Contribution", val: @payroll.sss_amount },
              { name: "PhilHealth",       val: @payroll.phic_amount },
              { name: "Pag-IBIG (HDMF)",  val: @payroll.hdmf_amount },
              { name: "SSS Loan",         val: @payroll.sss_loan },
              { name: "Pag-IBIG Loan",    val: @payroll.hdmf_loan },
              { name: "Cash Advance",     val: @payroll.cash_advance },
              { name: "Rice Deduction",   val: @payroll.rice_deduction },
              { name: "Groceries Ded.",   val: @payroll.groceries_deduction },
              { name: "Materials Ded.",   val: @payroll.materials_deduction },
              { name: "Late/Undertime",   val: @payroll.late_ut_amount }
            ]
          %>

          <%# Render Fixed Deductions %>
          <% fixed_deductions.each do |item| %>
            <% if item[:val].to_f > 0 %>
              <div class="d-flex justify-content-between mb-2">
                <span class="small fw-bold text-dark"><%= item[:name] %></span>
                <span class="text-danger small fw-semibold">- <%= number_to_currency(item[:val], unit: "₱") %></span>
              </div>
            <% end %>
          <% end %>

          <%# Render Dynamic/Miscellaneous Deductions (exclude Statutory — shown above) %>
          <% if @payroll.payroll_deductions.any? %>
            <% @payroll.payroll_deductions.reject { |pd| pd.note == "Statutory" }.each do |pd| %>
              <div class="d-flex justify-content-between mb-2">
                <div>
                  <span class="d-block small fw-bold text-dark">
                    <%= pd.deduction.present? ? pd.deduction.name : (pd.note.presence || "Manual Adjustment") %>
                  </span>
                </div>
                <span class="text-danger small fw-semibold">- <%= number_to_currency(pd.amount || 0, unit: "₱") %></span>
              </div>
            <% end %>
          <% end %>

          <%# Fallback Message %>
          <% if @payroll.total_deductions.to_f == 0 && !@payroll.payroll_deductions.any? %>
            <div class="text-muted small italic py-2 text-center">No deductions applied.</div>
          <% end %>

          <div class="d-flex justify-content-between fw-bold pt-2 border-top mt-3 text-danger p-2">
            <span>TOTAL DEDUCTIONS</span>
            <span>- <%= number_to_currency(@payroll.total_deductions || 0, unit: "₱") %></span>
          </div>
        </div>
      </div>

      <%# --- NET PAY FOOTER --- %>
      <div class="mt-5 p-4 bg-dark text-white rounded text-center shadow-lg">
        <h6 class="text-uppercase small mb-1 opacity-75">Net Take Home Pay</h6>
        <h1 class="display-4 fw-bold mb-0"><%= number_to_currency(@payroll.net_pay || 0, unit: "₱") %></h1>
        <small class="opacity-50">Generated: <%= @payroll.processed_at&.strftime("%m/%d/%Y %I:%M %p") || "—" %></small>
      </div>
    </div>
  </div>
</div>