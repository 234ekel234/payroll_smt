<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-wallet2"></i> Payroll Records</h1>
    <%= link_to new_payroll_path, class: "btn btn-outline-primary shadow-sm" do %>
      <i class="bi bi-plus-lg"></i> Add Manual Adjustment
    <% end %>
  </div>

  <% # UPDATED BATCH GENERATOR SECTION %>
  <div class="card mb-4 border-success shadow-sm">
    <div class="card-header bg-success text-white">
      <h5 class="card-title mb-0"><i class="bi bi-gear-fill"></i> Step 1: Batch Generate Payroll</h5>
    </div>
    <div class="card-body bg-light">
      <%= form_with url: generate_payrolls_path, method: :post do |f| %>
        <div class="row g-3">
          <%# Date Selectors %>
          <div class="col-md-3">
            <%= f.label :start_date, "Cut-off Start", class: "form-label fw-bold" %>
            <%= f.date_field :start_date, value: Date.today.beginning_of_month, class: "form-control border-success" %>
          </div>
          <div class="col-md-3">
            <%= f.label :end_date, "Cut-off End", class: "form-label fw-bold" %>
            <%= f.date_field :end_date, value: Date.today.end_of_month, class: "form-control border-success" %>
          </div>

          <%# Deduction Selection Checklist %>
          <div class="col-md-6">
            <label class="form-label fw-bold"><i class="bi bi-check2-square text-success"></i> Include Statutory Deductions:</label>
            <div class="p-2 border rounded bg-white shadow-sm d-flex flex-wrap gap-3">
              <%= f.collection_check_boxes :deduction_ids, Deduction.where(active: true), :id, :name do |b| %>
                <div class="form-check">
                  <%# Default to checked if it's a government/statutory deduction %>
                  <%= b.check_box(class: "form-check-input", checked: b.object.category == "Government") %>
                  <%= b.label(class: "form-check-label small fw-semibold") %>
                </div>
              <% end %>
            </div>
            <small class="text-muted italic">Uncheck items you don't want to calculate for this batch.</small>
          </div>

          <div class="col-12 mt-3">
            <button type="submit" class="btn btn-success px-4 py-2 shadow-sm" data-confirm="Generate payrolls for all employees with selected deductions?">
              <i class="bi bi-calculator"></i> Calculate All Employees
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% # PAYROLL TABLE SECTION %>
  <div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered align-middle bg-white mb-0">
      <thead class="table-dark text-nowrap">
        <tr>
          <th class="text-center">#</th>
          <th>Employee</th>
          <th>Period</th>
          <th class="text-end">Gross Pay</th>
          <th class="text-end text-warning">Deductions</th>
          <th class="text-end bg-primary text-white">Net Pay</th>
          <th class="text-center">Status</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @payrolls.any? %>
          <% @payrolls.each_with_index do |payroll, idx| %>
            <tr class="<%= 'table-warning' if payroll.status == 'draft' %>">
              <td class="text-center text-muted"><%= idx + 1 %></td>
              <td>
                <div class="fw-bold text-dark"><%= payroll.employee.name %></div>
                <small class="text-muted"><%= payroll.employee.person_id %></small>
              </td>
              <td>
                <span class="badge bg-light text-dark border">
                  <%= payroll.start_date&.strftime("%b %d") %> - <%= payroll.end_date&.strftime("%b %d") %>
                </span>
              </td>
              
              <td class="text-end fw-bold"><%= number_to_currency(payroll.gross_pay || 0, unit: "₱") %></td>
              <td class="text-end text-danger">
                <%= number_to_currency(payroll.total_deductions || 0, unit: "₱") %>
                <div class="small text-muted" style="font-size: 0.75rem;">
                  <%= pluralize(payroll.payroll_deductions.count, 'item') %>
                </div>
              </td>
              <td class="text-end fw-bold bg-light text-success">
                <%= number_to_currency(payroll.net_pay || 0, unit: "₱") %>
              </td>

              <td class="text-center">
                <% status_class = payroll.status == 'processed' ? 'bg-success' : 'bg-secondary' %>
                <span class="badge <%= status_class %>">
                  <%= (payroll.status || 'DRAFT').upcase %>
                </span>
              </td>
              <td>
                <div class="d-flex justify-content-center gap-1 text-nowrap">
                  <%= link_to payroll_path(payroll), class: "btn btn-sm btn-outline-info", title: "View Payslip" do %>
                    <i class="bi bi-printer"></i>
                  <% end %>
                  <%= link_to edit_payroll_path(payroll), class: "btn btn-sm btn-outline-warning", title: "Adjust Deductions" do %>
                    <i class="bi bi-pencil-square"></i>
                  <% end %>
                  <%= button_to payroll_path(payroll), method: :delete, class: "btn btn-sm btn-outline-danger", data: { confirm: "Permanently delete this record?" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="8" class="text-center py-5 text-muted">
              <i class="bi bi-inbox fs-1 d-block mb-2"></i>
              No payroll records found. Click "Calculate All" above to generate drafts.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>