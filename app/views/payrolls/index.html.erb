<h1 class="mb-4">Payrolls</h1>

<div class="mb-4 d-flex flex-wrap gap-2 justify-content-between align-items-center">
  <%= link_to "Add New Payroll", new_payroll_path, class: "btn btn-primary" %>
  <%= button_to "Generate Payroll", generate_payrolls_path, method: :post, class: "btn btn-success" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-bordered table-hover table-sm">
    <thead class="table-dark">
      <tr>
        <th>#</th>
        <th>Employee</th>
        <th>Period</th>
        <th>Daily Rate</th>
        <th>Days Worked</th>
        <th>Basic Pay</th>
        <th>Allowance</th>
        <th>Overtime Pay</th>
        <th>Rest Day Pay</th>
        <th>Holiday Pay</th>
        <th>Night Diff Pay</th>
        <th>Gross Pay</th>
        <th>Total Deductions</th>
        <th>Net Pay</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @payrolls.each_with_index do |payroll, idx| %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><%= payroll.employee.name %></td>
          <td>
            <%= payroll.start_date.strftime("%b %d, %Y") %> – 
            <%= payroll.end_date.strftime("%b %d, %Y") %>
          </td>
          <td><%= number_to_currency(payroll.daily_rate) %></td>
          <td><%= payroll.days_worked %></td>
          <td><%= number_to_currency(payroll.basic_pay) %></td>
          <td><%= number_to_currency(payroll.allowance) %></td>
          <td><%= number_to_currency(payroll.overtime_pay) %></td>
          <td><%= number_to_currency(payroll.rest_day_pay) %></td>
          <td><%= number_to_currency(payroll.holiday_pay) %></td>
          <td><%= number_to_currency(payroll.night_diff_pay) %></td>
          <td><%= number_to_currency(payroll.gross_pay) %></td>
          <td><%= number_to_currency(payroll.total_deductions) %></td>
          <td><%= number_to_currency(payroll.net_pay) %></td>
          <td><%= payroll.status.titleize %></td>
          <td class="d-flex gap-1 flex-wrap">
            <%= link_to "Show", payroll_path(payroll), class: "btn btn-sm btn-secondary" %>
            <%= link_to "Edit", edit_payroll_path(payroll), class: "btn btn-sm btn-warning" %>
            <%= button_to "Delete", payroll_path(payroll), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
