<div id="<%= dom_id payroll %>">
  <div>
    <strong>Employee:</strong>
    <%= payroll.employee_id %>
  </div>

  <div>
    <strong>Start date:</strong>
    <%= payroll.start_date %>
  </div>

  <div>
    <strong>End date:</strong>
    <%= payroll.end_date %>
  </div>

  <div>
    <strong>Daily rate:</strong>
    <%= payroll.daily_rate %>
  </div>

  <div>
    <strong>Days worked:</strong>
    <%= payroll.days_worked %>
  </div>

  <div>
    <strong>Allowance:</strong>
    <%= payroll.allowance %>
  </div>

  <div>
    <strong>Basic pay:</strong>
    <%= payroll.basic_pay %>
  </div>

  <div>
    <strong>Overtime pay:</strong>
    <%= payroll.overtime_pay %>
  </div>

  <div>
    <strong>Rest day pay:</strong>
    <%= payroll.rest_day_pay %>
  </div>

  <div>
    <strong>Holiday pay:</strong>
    <%= payroll.holiday_pay %>
  </div>

  <div>
    <strong>Night diff pay:</strong>
    <%= payroll.night_diff_pay %>
  </div>

  <div>
    <strong>Gross pay:</strong>
    <%= payroll.gross_pay %>
  </div>

  <div>
    <strong>Total deductions:</strong>
    <%= payroll.total_deductions %>
  </div>

  <div>
    <strong>Net pay:</strong>
    <%= payroll.net_pay %>
  </div>

  <div>
    <strong>Processed at:</strong>
    <%= payroll.processed_at %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= payroll.status %>
  </div>

</div>
