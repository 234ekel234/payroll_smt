<div class="mt-4">
  <%# Header Section %>
  <div class="row mb-4 align-items-center">
    <div class="col">
      <h1 class="h3 text-gray-800">
        <i class="bi bi-calendar-check text-primary me-2"></i>Attendance Summary
      </h1>
      <p class="text-muted">Reviewing lates, absences, and total rendered hours for the selected period.</p>
    </div>
  </div>

  <%# Advanced Filter Card %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-3 bg-white">
      <%= form_with url: attendance_report_path, method: :get, class: "row g-3 align-items-end" do |f| %>
        
        <%# Date Range Filters %>
        <div class="col-md-2">
          <label class="small fw-bold text-muted">Start Date</label>
          <%= f.date_field :start_date, value: @start_date, class: "form-control form-control-sm" %>
        </div>
        
        <div class="col-md-2">
          <label class="small fw-bold text-muted">End Date</label>
          <%= f.date_field :end_date, value: @end_date, class: "form-control form-control-sm" %>
        </div>

        <%# New: Employee Search %>
        <div class="col-md-3">
          <label class="small fw-bold text-muted">Search Employee</label>
          <%= f.text_field :employee_name, value: params[:employee_name], placeholder: "Type name...", class: "form-control form-control-sm" %>
        </div>

        <%# New: Company Filter %>
        <div class="col-md-2">
          <label class="small fw-bold text-muted">Company</label>
          <%= f.select :company, Employee.pluck(:company).compact.uniq, { include_blank: "All Companies", selected: params[:company] }, { class: "form-select form-select-sm" } %>
        </div>

        <%# New: Late Frequency Filter %>
        <div class="col-md-2">
          <label class="small fw-bold text-muted">Late Count</label>
          <%= f.select :late_filter, [["Show All", ""], ["3+ Lates (High Risk)", "3"], ["5+ Lates (Critical)", "5"]], { selected: params[:late_filter] }, { class: "form-select form-select-sm" } %>
        </div>

        <div class="col-md-1">
          <%= f.submit "Filter", class: "btn btn-sm btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Table Section %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light border-bottom">
          <tr class="text-secondary small text-uppercase">
            <th class="ps-3 py-3">Employee</th>
            <th class="text-center">Lates (Freq)</th>
            <th class="text-center">Late (Total Mins)</th>
            <th class="text-center">Absences</th>
            <th class="text-center">Work Hours</th>
            <th class="text-center">OT Hours</th>
            <th class="text-end pe-3">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if @report_data.any? %>
            <% @report_data.each do |data| %>
              <tr>
                <td class="ps-3">
                  <div class="fw-bold text-dark"><%= data[:employee]&.name || "Deleted/Unknown Employee" %></div>
                  <small class="text-muted"><%= data[:employee]&.company || "N/A" %></small>
                </td>
                
                <td class="text-center">
                  <% if data[:late_count] > 0 %>
                    <span class="badge rounded-pill <%= data[:late_count] > 3 ? 'bg-danger' : 'bg-warning text-dark' %>">
                      <%= data[:late_count] %> times
                    </span>
                  <% else %>
                    <span class="text-success small"><i class="bi bi-check-circle-fill"></i> Perfect</span>
                  <% end %>
                </td>

                <td class="text-center">
                  <% if data[:total_late_minutes] > 0 %>
                    <span class="text-danger fw-bold"><%= data[:total_late_minutes] %> <small>min</small></span>
                  <% else %>
                    <span class="text-muted small">-</span>
                  <% end %>
                </td>

                <td class="text-center">
                  <% if data[:absence_count] > 0 %>
                    <span class="badge bg-dark rounded-pill"><%= data[:absence_count] %></span>
                  <% else %>
                    <span class="text-muted small">0</span>
                  <% end %>
                </td>

                <td class="text-center">
                  <div class="fw-bold"><%= data[:work_hours] %>h</div>
                  <div class="progress mt-1" style="height: 4px; width: 60px; margin: 0 auto;">
                    <% max_hours = ((@end_date - @start_date).to_i + 1) * 8.0 %>
                    <% progress = [data[:work_hours] / max_hours * 100, 100].min %>
                    <div class="progress-bar bg-primary" style="width: <%= progress %>%"></div>
                  </div>
                </td>

                <td class="text-center text-primary fw-bold">
                  <%= data[:ot_hours] > 0 ? "#{data[:ot_hours]}h" : "-" %>
                </td>

                <td class="text-end pe-3">
                  <% if data[:employee] %>
                    <%= link_to daily_time_records_path(employee_name: data[:employee].name, start_date: @start_date, end_date: @end_date), class: "btn btn-sm btn-outline-secondary py-1 px-3" do %>
                      View Logs
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-inbox h1 d-block"></i> No records found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>