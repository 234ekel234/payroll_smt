<div class="container-fluid mt-4">
  <%# Header Section %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 text-dark fw-bold mb-0">Daily Time Records</h1>
      <p class="text-muted small">Comprehensive audit of employee attendance and shift slicing.</p>
    </div>
    
    <div class="d-flex gap-2">
      <%= form_with url: import_google_daily_time_records_path, local: true, method: :post, class: "d-inline-flex gap-2 p-2 bg-white rounded border shadow-sm align-items-center" do |f| %>
        <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Google Sync:</small>
        <%= f.text_field :spreadsheet_id, placeholder: "Sheet ID...", class: "form-control form-control-sm", style: "width: 180px;" %>
        <button type="submit" class="btn btn-sm btn-info text-white px-3 rounded-pill d-flex align-items-center shadow-sm">
          <i class="bi bi-arrow-repeat me-1"></i> Sync Data
        </button>
      <% end %>
    </div>
  </div>

  <%# Search & Filter Section %>
  <div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body p-3">
      <%= form_with url: daily_time_records_path, method: :get, class: "row g-2 align-items-end" do |f| %>
        <div class="col-md-2">
          <label class="small fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Employee</label>
          <%= f.text_field :employee_name, value: params[:employee_name], placeholder: "Name...", class: "form-control form-control-sm border-0 shadow-sm" %>
        </div>

        <div class="col-md-2">
          <label class="small fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Company</label>
          <%= f.select :company, Employee.distinct.pluck(:company).compact.sort, { include_blank: "All Companies", selected: params[:company] }, { class: "form-select form-select-sm border-0 shadow-sm" } %>
        </div>

        <div class="col-md-2">
          <label class="small fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">Start Date</label>
          <%= f.date_field :start_date, value: params[:start_date], class: "form-control form-control-sm border-0 shadow-sm" %>
        </div>
        <div class="col-md-2">
          <label class="small fw-bold text-muted text-uppercase" style="font-size: 0.65rem;">End Date</label>
          <%= f.date_field :end_date, value: params[:end_date], class: "form-control form-control-sm border-0 shadow-sm" %>
        </div>

        <div class="col-md-4 d-flex gap-1">
          <button type="submit" class="btn btn-sm btn-dark flex-grow-1 rounded-pill shadow-sm">
            <i class="bi bi-search me-1"></i> Apply Filter
          </button>
          <%= link_to daily_time_records_path, class: "btn btn-sm btn-outline-secondary rounded-pill shadow-sm" do %>
            <i class="bi bi-x-circle me-1"></i> Reset
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Data Table %>
  <div class="card shadow-sm border-0 overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-white border-bottom">
          <tr>
            <th class="ps-4 py-3 text-muted small fw-bold text-uppercase">Employee</th>
            <th class="text-muted small fw-bold text-uppercase">Date</th>
            <th class="text-muted small fw-bold text-uppercase">Clock In/Out</th>
            <th class="text-center text-muted small fw-bold text-uppercase">Regular</th>
            <th class="text-center text-muted small fw-bold text-uppercase text-primary">OT</th>
            <th class="text-center text-muted small fw-bold text-uppercase text-indigo">Night</th>
            <th class="text-center text-muted small fw-bold text-uppercase text-danger">Holiday</th>
            <th class="text-muted small fw-bold text-uppercase">Status</th>
            <th class="text-end pe-4 text-muted small fw-bold text-uppercase">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @daily_time_records&.any? %>
            <% @daily_time_records.each do |dtr| %>
              <%# Compute all slice-based values once per row %>
              <% ot_minutes      = dtr.time_slices.select(&:overtime).sum(&:minutes).to_i %>
              <% nd_minutes      = dtr.time_slices.select(&:night_diff).sum(&:minutes).to_i %>
              <% holiday_minutes = dtr.time_slices.select(&:holiday).sum(&:minutes).to_i %>
              <% regular_minutes = dtr.time_slices.reject(&:overtime).sum(&:minutes).to_i %>

              <tr class="<%= 'table-danger-subtle' if dtr.abnormal_situation == 'Absence' %>">
                <td class="ps-4">
                  <div class="fw-bold text-dark"><%= dtr.employee&.name %></div>
                  <div class="d-flex align-items-center gap-1">
                    <% if dtr.employee&.shift %>
                      <span class="badge bg-primary-subtle text-primary border-0" style="font-size: 0.6rem;">
                        <i class="bi bi-clock-history"></i> <%= dtr.employee.shift.name %>
                      </span>
                    <% end %>
                    <small class="text-muted" style="font-size: 0.7rem;"><%= dtr.employee&.company %></small>
                  </div>
                </td>

                <td class="text-nowrap fw-bold text-secondary">
                  <%= dtr.date&.strftime("%m/%d/%Y") %>
                </td>

                <td>
                  <div class="text-success small fw-bold"><%= dtr.clock_in&.strftime("%I:%M %p") || "--:--" %></div>
                  <div class="text-danger small fw-bold"><%= dtr.clock_out&.strftime("%I:%M %p") || "--:--" %></div>
                </td>

                <%# REGULAR WORK — slices where overtime is false %>
                <td class="text-center">
                  <% h, m = regular_minutes.divmod(60) %>
                  <span class="fw-bold text-dark">
                    <%= "#{h}h " if h > 0 %><%= "#{m}m" if m > 0 %>
                    <%= "-" if h <= 0 && m <= 0 %>
                  </span>
                </td>

                <%# OVERTIME — slices where overtime is true %>
                <td class="text-center">
                  <% h, m = ot_minutes.divmod(60) %>
                  <% if h > 0 || m > 0 %>
                    <span class="badge bg-primary px-2 rounded-pill shadow-sm">
                      <i class="bi bi-plus-circle me-1"></i><%= "#{h}h " if h > 0 %><%= "#{m}m" %>
                    </span>
                  <% else %>
                    <span class="text-muted small">-</span>
                  <% end %>
                </td>

                <%# NIGHT DIFF — slices where night_diff is true %>
                <td class="text-center">
                  <% h, m = nd_minutes.divmod(60) %>
                  <% if h > 0 || m > 0 %>
                    <span class="badge px-2 rounded-pill text-white shadow-sm" style="background-color: #6610f2;">
                      <i class="bi bi-moon-stars me-1"></i><%= "#{h}h " if h > 0 %><%= "#{m}m" %>
                    </span>
                  <% else %>
                    <span class="text-muted small">-</span>
                  <% end %>
                </td>

                <%# HOLIDAY — slices where holiday is true %>
                <td class="text-center">
                  <% h, m = holiday_minutes.divmod(60) %>
                  <% if h > 0 || m > 0 %>
                    <span class="badge bg-danger px-2 rounded-pill shadow-sm">
                      <i class="bi bi-calendar-check me-1"></i><%= "#{h}h " if h > 0 %><%= "#{m}m" %>
                    </span>
                  <% else %>
                    <span class="text-muted small">-</span>
                  <% end %>
                </td>

                <td>
                  <% if dtr.abnormal_situation == "Absence" %>
                    <span class="badge bg-danger px-2 rounded-pill small shadow-sm">Absence</span>
                  <% elsif dtr.late_minutes.to_i > 0 %>
                    <span class="text-warning fw-bold small" style="font-size: 0.75rem;">
                      <i class="bi bi-exclamation-circle"></i> Late <%= dtr.late_minutes %>m
                    </span>
                  <% else %>
                    <span class="text-success small"><i class="bi bi-check-circle-fill"></i> Normal</span>
                  <% end %>
                </td>

                <td class="text-end pe-4">
                  <div class="btn-group shadow-sm">
                    <%= link_to daily_time_record_path(dtr), class: "btn btn-sm btn-outline-primary d-inline-flex align-items-center" do %>
                      <i class="bi bi-eye me-1"></i> View Record
                    <% end %>
                    <%= link_to edit_daily_time_record_path(dtr), class: "btn btn-sm btn-outline-secondary d-inline-flex align-items-center" do %>
                      <i class="bi bi-pencil me-1"></i> Edit
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="9" class="text-center py-5 text-muted">No records found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# PAGINATION FOOTER %>
    <div class="card-footer bg-white py-3 border-top-0">
      <div class="d-flex justify-content-between align-items-center">
        <div class="text-muted small">
          Showing records <strong><%= @pagy.from %></strong> to <strong><%= @pagy.to %></strong>
        </div>
        <div>
          <%== pagy_bootstrap_nav(@pagy) %>
        </div>
      </div>
    </div>
  </div>
</div>
