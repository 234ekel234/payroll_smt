<div class="container-fluid mt-4">
  <%# Header Section %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h3 text-gray-800 mb-0">Daily Time Records</h1>
      <p class="text-muted small">Manage and audit daily employee logs.</p>
    </div>
    
    <%= form_with url: import_google_daily_time_records_path, local: true, method: :post, class: "d-inline-flex gap-2 p-2 bg-white rounded border shadow-sm align-items-center" do |f| %>
      <small class="text-muted fw-bold"><i class="bi bi-google"></i> Sync:</small>
      <%= f.text_field :spreadsheet_id, placeholder: "Google Sheet ID", class: "form-control form-control-sm", style: "width: 180px;" %>
      <%= f.submit "Sync", class: "btn btn-sm btn-info text-white px-3 rounded-pill" %>
    <% end %>
  </div>

  <%# Search & Filter Section %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white py-2">
      <span class="small fw-bold text-uppercase text-muted"><i class="bi bi-funnel"></i> Search & Filters</span>
    </div>
    <div class="card-body p-3 bg-white">
      <%= form_with url: daily_time_records_path, method: :get, class: "row g-3 align-items-end" do |f| %>
        <div class="col-md-2">
          <label class="small fw-bold text-muted">Employee Name</label>
          <%= f.text_field :employee_name, value: params[:employee_name], placeholder: "Search name...", class: "form-control form-control-sm" %>
        </div>

        <div class="col-md-2">
          <label class="small fw-bold text-muted">Company</label>
          <%= f.select :company, Employee.pluck(:company).compact.uniq, { include_blank: "All Companies", selected: params[:company] }, { class: "form-select form-select-sm" } %>
        </div>

        <div class="col-md-2">
          <label class="small fw-bold text-muted">Status Type</label>
          <%= f.select :status, [["Normal Logs", "Normal"], ["Lates/Abnormal", "Abnormal"], ["Absences", "Absence"]], { include_blank: "All Records", selected: params[:status] }, { class: "form-select form-select-sm" } %>
        </div>

        <div class="col-md-2">
          <label class="small fw-bold text-muted">Start Date</label>
          <%= f.date_field :start_date, value: params[:start_date], class: "form-control form-control-sm" %>
        </div>

        <div class="col-md-2">
          <label class="small fw-bold text-muted">End Date</label>
          <%= f.date_field :end_date, value: params[:end_date], class: "form-control form-control-sm" %>
        </div>

        <div class="col-md-2 d-flex gap-1">
          <%= f.submit "Filter", class: "btn btn-sm btn-primary flex-grow-1 rounded-pill" %>
          <%= link_to "Reset", daily_time_records_path, class: "btn btn-sm btn-outline-secondary rounded-pill" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Data Table %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3 py-3">Employee</th>
            <th>Date</th>
            <th>Clock In</th>
            <th>Clock Out</th>
            <th class="text-center">Work (hrs)</th>
            <th class="text-center">OT</th>
            <th class="text-center">Night</th>
            <th class="text-center">Holiday</th>
            <th>Status</th>
            <th class="text-end pe-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @daily_time_records&.any? %>
            <% @daily_time_records.each do |dtr| %>
              <tr class="<%= 'table-danger-subtle' if dtr.abnormal_situation == 'Absence' %> <%= 'table-warning' if dtr.abnormal_situation.present? && dtr.abnormal_situation != 'Absence' %>">
                <td class="ps-3">
                  <div class="fw-bold text-dark"><%= dtr.employee&.name || "Unknown" %></div>
                  <small class="text-muted"><%= dtr.employee&.company %> • ID: <%= dtr.employee&.person_id %></small>
                </td>
                <td class="text-nowrap"><%= dtr.date&.strftime("%b %d, %Y") %></td>
                <td class="text-success small fw-bold"><%= dtr.clock_in&.strftime("%I:%M %p") || "--:--" %></td>
                <td class="text-danger small fw-bold"><%= dtr.clock_out&.strftime("%I:%M %p") || "--:--" %></td>
                
                <td class="text-center">
                  <% hours = (dtr.total_work_minutes.to_f / 60.0).round(2) %>
                  <span class="badge bg-secondary-subtle text-secondary border">
                    <%= hours %>h
                  </span>
                </td>
                
                <td class="text-center text-muted small"><%= dtr.overtime_minutes.to_i > 0 ? "#{(dtr.overtime_minutes.to_f / 60.0).round(1)}h" : "-" %></td>
                <td class="text-center text-muted small"><%= dtr.night_diff_minutes.to_i > 0 ? "#{(dtr.night_diff_minutes.to_f / 60.0).round(1)}h" : "-" %></td>
                <td class="text-center text-muted small"><%= dtr.holiday_minutes.to_i > 0 ? "#{(dtr.holiday_minutes.to_f / 60.0).round(1)}h" : "-" %></td>

                <td>
                  <% if dtr.abnormal_situation == "Absence" %>
                    <span class="badge bg-danger px-2 rounded-pill"><i class="bi bi-x-circle"></i> Absence</span>
                  <% elsif dtr.abnormal_situation.present? %>
                    <span class="badge bg-warning text-dark border border-warning px-2 rounded-pill">
                      <i class="bi bi-exclamation-triangle"></i> <%= dtr.abnormal_situation %>
                    </span>
                  <% else %>
                    <span class="text-success small"><i class="bi bi-check-circle-fill"></i> Normal</span>
                  <% end %>
                </td>

                <td class="text-end pe-3 text-nowrap">
                  <%# VIEW BUTTON %>
                  <%= link_to daily_time_record_path(dtr), class: "btn btn-sm btn-outline-primary rounded-pill px-3 me-1" do %>
                    <i class="bi bi-eye"></i> View
                  <% end %>
                  
                  <%# EDIT BUTTON %>
                  <%= link_to edit_daily_time_record_path(dtr), class: "btn btn-sm btn-outline-secondary rounded-pill px-3" do %>
                    <i class="bi bi-pencil"></i> Edit
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="10" class="text-center py-5">
                <div class="text-muted">
                  <i class="bi bi-search h1 d-block mb-3"></i>
                  No records found matching those filters.
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# PAGINATION FOOTER %>
    <div class="card-footer bg-white py-3">
      <div class="d-flex justify-content-between align-items-center">
        <div class="text-muted small">
          Showing <strong><%= @pagy.from %></strong> to <strong><%= @pagy.to %></strong> of <strong><%= @pagy.count %></strong> records
        </div>
        <div>
          <%== pagy_bootstrap_nav(@pagy) %>
        </div>
      </div>
    </div>
  </div>
</div>