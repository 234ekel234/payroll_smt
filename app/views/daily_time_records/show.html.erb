<div class="container mt-4">
  <%# Header Section %>
  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
      <h1 class="h3 mb-1">Daily Time Record</h1>
      <p class="text-muted mb-0">
        <i class="bi bi-calendar3"></i> <%= @daily_time_record.date.strftime("%A, %B %d, %Y") %>
      </p>
    </div>
    <div class="btn-group">
      <%= link_to "Edit Record", edit_daily_time_record_path(@daily_time_record), class: "btn btn-outline-warning" %>
      <%= link_to "Back to List", daily_time_records_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-4">
      <%# Employee Card %>
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white py-3">
          <h5 class="card-title mb-0">Employee Context</h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <small class="text-muted d-block">Employee Name</small>
            <span class="fw-bold fs-5"><%= @daily_time_record.employee.name %></span>
          </div>
          <div class="row mb-3">
            <div class="col-6">
              <small class="text-muted d-block">Standard Shift</small>
              <span class="small"><%= @daily_time_record.employee.shift_start.strftime("%I:%M %p") %> - <%= @daily_time_record.employee.shift_end.strftime("%I:%M %p") %></span>
            </div>
            <div class="col-6">
              <small class="text-muted d-block">Hourly Rate</small>
              <span class="fw-bold text-success">₱<%= number_with_precision(@daily_time_record.employee.basic_rate / 8.0, precision: 2) %></span>
            </div>
          </div>
          <hr>
          <div class="mb-2 d-flex justify-content-between">
            <span class="text-muted">Clock In:</span>
            <span class="badge bg-light text-dark border fw-normal"><%= @daily_time_record.clock_in&.strftime("%I:%M %p") || "-" %></span>
          </div>
          <div class="mb-2 d-flex justify-content-between">
            <span class="text-muted">Clock Out:</span>
            <span class="badge bg-light text-dark border fw-normal"><%= @daily_time_record.clock_out&.strftime("%I:%M %p") || "-" %></span>
          </div>
        </div>
      </div>

      <%# Fixed Summary of Hours Section %>
      <div class="card shadow-sm border-0">
        <div class="card-body p-0">
          <table class="table mb-0">
            <tr class="table-light"><th colspan="2" class="px-3 py-2">Summary of Hours</th></tr>
            <% 
              # Dynamically sum slices to ensure accuracy against the detail table
              summary_items = [
                ["Total Work", @daily_time_record.time_slices.sum(:minutes), "text-dark"],
                ["Overtime", @daily_time_record.time_slices.where(overtime: true).sum(:minutes), "text-primary"],
                ["Holiday", @daily_time_record.time_slices.where(holiday: true).sum(:minutes), "text-warning-emphasis"],
                ["Late", @daily_time_record.late_minutes, "text-danger"]
              ]
            %>
            <% summary_items.each do |label, mins, css| %>
              <tr>
                <td class="px-3 <%= css %>"><%= label %></td>
                <td class="text-end px-3 fw-bold <%= css %>">
                  <% h, m = mins.to_i.divmod(60) %>
                  <%= "#{h}h " if h > 0 %><%= "#{m}m" %>
                </td>
              </tr>
            <% end %>
          </table>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <%# Detailed Slices Table %>
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
          <h5 class="card-title mb-0">Detailed Time Slices</h5>
          <small class="text-muted">Calculated segments based on labor rules.</small>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
              <tr>
                <th class="ps-3">#</th>
                <th>Time Segment</th>
                <th class="text-center">Duration</th>
                <th>Conditions</th>
                <th class="text-end pe-3">Multiplier</th>
              </tr>
            </thead>
            <tbody>
              <% if @daily_time_record.time_slices.any? %>
                <% @daily_time_record.time_slices.order(:start_time).each_with_index do |slice, idx| %>
                  <tr>
                    <td class="ps-3 text-muted"><%= idx + 1 %></td>
                    <td>
                      <div class="fw-bold text-nowrap">
                        <%= slice.start_time.strftime("%I:%M %p") %> – <%= slice.end_time.strftime("%I:%M %p") %>
                      </div>
                    </td>
                    <td class="text-center fw-bold">
                      <% h, m = slice.minutes.to_i.divmod(60) %>
                      <%= "#{h}h " if h > 0 %><%= "#{m}m" %>
                    </td>
                    <td>
                      <div class="d-flex flex-wrap gap-1">
                        <% if slice.night_diff %><span class="badge bg-secondary" style="font-size: 0.65rem;">NIGHT</span><% end %>
                        <% if slice.overtime %><span class="badge bg-primary" style="font-size: 0.65rem;">OT</span><% end %>
                        <% if slice.holiday %><span class="badge bg-warning text-dark" style="font-size: 0.65rem;">HOLIDAY</span><% end %>
                        <% if slice.rest_day %><span class="badge bg-success" style="font-size: 0.65rem;">REST DAY</span><% end %>
                      </div>
                    </td>
                    <td class="text-end pe-3">
                      <span class="fw-bold text-dark">x<%= number_with_precision((slice.multiplier_percent || 0) / 100.0, precision: 2) %></span>
                      
                      <% if slice.night_diff %>
                        <div class="text-secondary fw-bold" style="font-size: 0.75rem;">
                          <i class="bi bi-plus-circle-fill"></i> 10% Night
                        </div>
                      <% end %>
                      <small class="text-muted d-block" style="font-size: 0.7rem;"><%= slice.multiplier_code %></small>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="text-center py-4 text-muted">No time segments calculated for this record.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="card-footer bg-light py-3">
          <p class="small text-muted mb-0">
            <i class="bi bi-info-circle"></i> 
            Night Differential is an additive 10% of the base hourly rate, as per company policy.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>