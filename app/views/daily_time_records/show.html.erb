<h1>Daily Time Record Details</h1>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-dark text-white">
    <strong><%= @daily_time_record.employee.name %></strong> - <%= @daily_time_record.date.strftime("%Y-%m-%d") %>
  </div>
  <div class="card-body p-3">
    <div class="row mb-2">
      <div class="col-md-3"><strong>Clock In:</strong> <%= @daily_time_record.clock_in&.strftime("%I:%M %p") || "-" %></div>
      <div class="col-md-3"><strong>Clock Out:</strong> <%= @daily_time_record.clock_out&.strftime("%I:%M %p") || "-" %></div>
      <div class="col-md-3"><strong>Total Work:</strong> <%= @daily_time_record.total_work_minutes || 0 %> min</div>
      <div class="col-md-3"><strong>Holiday Minutes:</strong> <%= @daily_time_record.holiday_minutes || 0 %> min</div>
    </div>

    <div class="row mb-2">
      <div class="col-md-3"><strong>Late:</strong> <%= @daily_time_record.late_minutes || 0 %> min</div>
      <div class="col-md-3"><strong>Early Leave:</strong> <%= @daily_time_record.early_leave_minutes || 0 %> min</div>
      <div class="col-md-3"><strong>Night Diff:</strong> <%= @daily_time_record.night_diff_minutes || 0 %> min</div>
      <div class="col-md-3"><strong>Overtime:</strong> <%= @daily_time_record.overtime_minutes || 0 %> min</div>
    </div>

    <% if @daily_time_record.abnormal_situation.present? %>
      <div class="row mt-2">
        <div class="col text-danger"><strong>Abnormal Situation:</strong> <%= @daily_time_record.abnormal_situation %></div>
      </div>
    <% end %>
  </div>

  <div class="card-footer d-flex gap-2 flex-wrap">
    <%= link_to "Back", daily_time_records_path, class: "btn btn-secondary" %>
    <%= link_to "Edit", edit_daily_time_record_path(@daily_time_record), class: "btn btn-warning" %>
    <%= button_to "Delete", daily_time_record_path(@daily_time_record), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
  </div>
</div>
