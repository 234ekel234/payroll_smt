<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
      <h1 class="h3 mb-1">Daily Time Record</h1>
      <p class="text-muted mb-0">
        <i class="bi bi-calendar3"></i> <%= @daily_time_record.date.strftime("%A, %B %d, %Y") %>
      </p>
    </div>
    <div class="btn-group">
      <%= link_to "Edit Record", edit_daily_time_record_path(@daily_time_record), class: "btn btn-outline-warning" %>
      <%= link_to "Back to List", daily_time_records_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-4">
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white py-3">
          <h5 class="card-title mb-0">Employee Context</h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <small class="text-muted d-block">Employee Name</small>
            <span class="fw-bold fs-5"><%= @daily_time_record.employee.name %></span>
          </div>
          <div class="row mb-3">
            <div class="col-6">
              <small class="text-muted d-block">Standard Shift</small>
              <span><%= @daily_time_record.employee.shift_start.strftime("%I:%M %p") %> - <%= @daily_time_record.employee.shift_end.strftime("%I:%M %p") %></span>
            </div>
            <div class="col-6">
              <small class="text-muted d-block">Hourly Rate</small>
              <span class="fw-bold text-success">$<%= number_with_precision(@daily_time_record.employee.basic_rate, precision: 2) %></span>
            </div>
          </div>
          <hr>
          <div class="mb-2 d-flex justify-content-between">
            <span class="text-muted">Clock In:</span>
            <span class="badge bg-light text-dark border"><%= @daily_time_record.clock_in&.strftime("%I:%M %p") || "-" %></span>
          </div>
          <div class="mb-2 d-flex justify-content-between">
            <span class="text-muted">Clock Out:</span>
            <span class="badge bg-light text-dark border"><%= @daily_time_record.clock_out&.strftime("%I:%M %p") || "-" %></span>
          </div>
          <div class="mt-3">
            <small class="text-muted fw-bold d-block mb-2">Abnormal Situations</small>
            <% if @daily_time_record.abnormal_situation.present? %>
              <% @daily_time_record.abnormal_situation.split(', ').each do |issue| %>
                <span class="badge bg-danger rounded-pill me-1"><%= issue %></span>
              <% end %>
            <% else %>
              <span class="badge bg-success rounded-pill">Normal Attendance</span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body p-0">
          <table class="table mb-0">
            <tr class="table-light"><th colspan="2" class="px-3">Aggregates (Minutes)</th></tr>
            <tr><td class="px-3">Total Work</td><td class="text-end px-3 fw-bold"><%= @daily_time_record.total_work_minutes %>m</td></tr>
            <tr><td class="px-3 text-primary">Overtime</td><td class="text-end px-3 fw-bold text-primary"><%= @daily_time_record.overtime_minutes %>m</td></tr>
            <tr><td class="px-3 text-secondary">Night Diff</td><td class="text-end px-3 fw-bold text-secondary"><%= @daily_time_record.night_diff_minutes %>m</td></tr>
            <tr><td class="px-3 text-warning-emphasis">Holiday</td><td class="text-end px-3 fw-bold text-warning-emphasis"><%= @daily_time_record.holiday_minutes %>m</td></tr>
            <tr><td class="px-3 text-danger">Late</td><td class="text-end px-3 fw-bold text-danger"><%= @daily_time_record.late_minutes %>m</td></tr>
          </table>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
          <h5 class="card-title mb-0">Detailed Time Slices</h5>
          <small class="text-muted">Automatically computed based on shift boundaries and multipliers.</small>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
              <tr>
                <th class="ps-3">#</th>
                <th>Time Segment</th>
                <th class="text-center">Work Mins</th>
                <th>Conditions</th>
                <th class="text-end pe-3">Multiplier</th>
              </tr>
            </thead>
            <tbody>
              <% @daily_time_record.time_slices.each_with_index do |slice, idx| %>
                <tr>
                  <td class="ps-3 text-muted"><%= idx + 1 %></td>
                  <td>
                    <div class="fw-bold"><%= slice.start_time.strftime("%I:%M %p") %> - <%= slice.end_time.strftime("%I:%M %p") %></div>
                  </td>
                  <td class="text-center fw-bold"><%= slice.minutes %></td>
                  <td>
                    <div class="d-flex flex-wrap gap-1">
                      <% if slice.night_diff %><span class="badge bg-secondary" style="font-size: 0.65rem;">NIGHT</span><% end %>
                      <% if slice.overtime %><span class="badge bg-primary" style="font-size: 0.65rem;">OT</span><% end %>
                      <% if slice.holiday %><span class="badge bg-warning text-dark" style="font-size: 0.65rem;">HOLIDAY</span><% end %>
                      <% if slice.rest_day %><span class="badge bg-success" style="font-size: 0.65rem;">REST DAY</span><% end %>
                      <% if !slice.night_diff && !slice.overtime && !slice.holiday && !slice.rest_day %>
                        <span class="text-muted small">Ordinary</span>
                      <% end %>
                    </div>
                  </td>
                  <td class="text-end pe-3">
                    <span class="fw-bold text-dark">x<%= number_with_precision(slice.multiplier, precision: 2) %></span><br>
                    <small class="text-muted" style="font-size: 0.7rem;"><%= slice.multiplier_name %></small>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="card-footer bg-light py-3">
          <p class="small text-muted mb-0">
            <i class="bi bi-info-circle"></i> 
            Work minutes exclude overlapping break times (<%= @daily_time_record.employee.break_start&.strftime("%I:%M %p") %> - <%= @daily_time_record.employee.break_end&.strftime("%I:%M %p") %>).
          </p>
        </div>
      </div>
    </div>
  </div>
</div>