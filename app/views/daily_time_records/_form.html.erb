<%= form_with(model: @daily_time_record, local: true) do |f| %>
  <% if @daily_time_record.errors.any? %>
    <div class="alert alert-danger">
      <h4>Errors:</h4>
      <ul>
        <% @daily_time_record.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :employee_id, "Employee" %>
    <%= f.collection_select :employee_id, Employee.all, :id, :name, { prompt: "Select Employee" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :date %>
    <%= f.date_field :date, class: "form-control" %>
  </div>

  <div class="mb-3 row">
    <div class="col">
      <%= f.label :clock_in %>
      <%= f.time_field :clock_in, class: "form-control" %>
    </div>
    <div class="col">
      <%= f.label :clock_out %>
      <%= f.time_field :clock_out, class: "form-control" %>
    </div>
  </div>

  <!-- Optional: Display computed slices preview -->
  <% if @daily_time_record.slices.any? %>
    <h5 class="mt-3">Computed Slices (Preview)</h5>
    <ul>
      <% @daily_time_record.slices.each do |slice| %>
        <li>
          <%= slice[:start_time].strftime("%I:%M %p") %> - <%= slice[:end_time].strftime("%I:%M %p") %>
          (<%= slice[:minutes] %> min)
          <% if slice[:night_diff] %> <span class="badge bg-dark">Night</span> <% end %>
          <% if slice[:holiday] %> <span class="badge bg-info">Holiday</span> <% end %>
          <% if slice[:rest_day] %> <span class="badge bg-warning text-dark">Rest Day</span> <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <div class="mt-3">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", daily_time_records_path, class: "btn btn-secondary" %>
  </div>
<% end %>
