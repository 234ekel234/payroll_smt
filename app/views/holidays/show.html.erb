<h1>Holiday Details</h1>

<p>
  <strong>Date:</strong> <%= @holiday.date.strftime("%B %d, %Y") %><br>
  <strong>Name:</strong> <%= @holiday.name %><br>
  <strong>Type:</strong> <%= @holiday.holiday_type %><br>
  <strong>Applies To:</strong> <%= @holiday.applies_to %><br>
  <strong>Notes:</strong> <%= @holiday.notes %>
</p>

<div class="d-flex gap-2">
  <%= link_to "Edit", edit_holiday_path(@holiday), class: "btn btn-warning" %>
  <%= link_to "Back", holidays_path, class: "btn btn-secondary" %>
</div>
