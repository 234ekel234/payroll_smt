<h1 class="mb-4">Holidays</h1>

<div class="mb-4 d-flex justify-content-between align-items-center">
  <%= link_to "Add Holiday", new_holiday_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-bordered table-hover table-sm">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Date</th>
      <th>Name</th>
      <th>Type</th>
      <th>Applies To</th>
      <th>Notes</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @holidays.each_with_index do |holiday, idx| %>
      <tr>
        <td><%= idx + 1 %></td>
        <td><%= holiday.date.strftime("%B %d, %Y") %></td>
        <td><%= holiday.name %></td>
        <td><%= holiday.holiday_type %></td>
        <td><%= holiday.applies_to %></td>
        <td><%= holiday.notes %></td>
        <td>
          <%= link_to "Show", holiday_path(holiday), class: "btn btn-sm btn-secondary" %>
          <%= link_to "Edit", edit_holiday_path(holiday), class: "btn btn-sm btn-warning" %>
          <%= button_to "Delete", holiday_path(holiday), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
